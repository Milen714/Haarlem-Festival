<mxfile host="app.diagrams.net" agent="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/146.0.0.0 Safari/537.36">
  <diagram name="Page-1" id="gvMFIAKkD2ep_Sjr8MSZ">
    <mxGraphModel dx="4427" dy="2679" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\ntitle Stripe Ticket Fulfillment - Class Diagram\n\nskinparam backgroundColor white\nskinparam shadowing false\nskinparam packageStyle rectangle\nskinparam classAttributeIconSize 0\nskinparam ArrowColor #4b5563\nskinparam ClassBorderColor #1f2937\nskinparam ClassBackgroundColor #f8fafc\nskinparam InterfaceBorderColor #0f766e\nskinparam InterfaceBackgroundColor #ecfeff\nskinparam NoteBackgroundColor #fff7ed\nskinparam NoteBorderColor #c2410c\n\nhide empty members\n\nclass \&quot;FastRoute Router\\n(public/index.php)\&quot; as Router &lt;&lt;router&gt;&gt; {\n  +dispatch(httpMethod, uri)\n}\n\npackage \&quot;Controllers\&quot; {\n  abstract class BaseController {\n    #renderViewToString(viewPath: string, data: array): string\n    #sendSuccessResponse(data: array, code: int = 200): void\n  }\n\n  class StripeWebhookController {\n    -paymentService: IPaymentService\n    -orderService: IOrderService\n    -ticketService: ITicketService\n    -ticketFulfillmentService: ITicketFulfillmentService\n    -mailService: IMailService\n    +handle(params: array = []): void\n  }\n}\n\npackage \&quot;Services\&quot; {\n  interface IPaymentService {\n    +verifyWebhookSignature(payload: string, sigHeader: string)\n  }\n\n  interface IOrderService {\n    +getOrderByStripeCheckoutSessionId(sessionId: string): Order\n    +updateOrderStatus(orderId: int, status: OrderStatus, pdf: string = null): bool\n    +generateTicketHashes(orderId: int): void\n    +getOrderById(orderId: int): Order\n  }\n\n  interface ITicketService {\n    +releaseOrderItems(orderItems: array): void\n  }\n\n  interface ITicketFulfillmentService {\n    +sendTicketEmail(order: Order, pdfHtml: string, emailHtml: string): string\n    +generatePDF(html: string, fileName: string): void\n    +generatePDFName(order: Order): string\n  }\n\n  interface IMailService {\n    +sendEmail(to: string, subject: string, body: string, attachments: array = []): void\n  }\n\n  class PaymentService {\n    +verifyWebhookSignature(payload: string, sigHeader: string)\n    +stripeCheckout(item: object)\n    +stripeCheckoutStatus(jsonData: array): array\n  }\n\n  class OrderService {\n    -orderRepository: IOrderRepository\n    -ticketService: TicketService\n    +getOrderByStripeCheckoutSessionId(sessionId: string): Order\n    +updateOrderStatus(orderId: int, status: OrderStatus, pdf: string = null): bool\n    +generateTicketHashes(orderId: int): void\n    +getOrderById(orderId: int): Order\n  }\n\n  class TicketService {\n    -ticketRepository: ITicketRepository\n    +releaseOrderItems(orderItems: array): void\n    +reserveMultiple(items: array): bool\n    +getTicketTypeIdsBySchemeId(schemeId: int): array\n    +getAvailableCapacity(ticketTypeId: int): int\n  }\n\n  class TicketFulfillmentService {\n    -orderService: IOrderService\n    -mailService: IMailService\n    +sendTicketEmail(order: Order, pdfHtml: string, emailHtml: string): string\n    +generatePDF(html: string, fileName: string): void\n    +generatePDFName(order: Order): string\n    +validateAndGetTicketPdf(pdfPath: string): string\n  }\n\n  class MailService {\n    +sendEmail(to: string, subject: string, body: string, attachments: array = []): void\n    +resetPasswordMail(to: string, resetLink: string): void\n    +accountVerificationMail(to: string, verificationLink: string): void\n  }\n\n  class Mailer {\n    -mail: PHPMailer\n    +send(recipient: string, body: string, subject: string, attachments: array = []): bool\n  }\n}\n\npackage \&quot;Repositories\&quot; {\n  abstract class Repository {\n    #pdo: PDO\n  }\n\n  interface IOrderRepository {\n    +getOrderByStripeCheckoutSessionId(sessionId: string): Order\n    +updateOrderStatus(orderId: int, status: OrderStatus, pdf: string = null): bool\n    +getOrderById(orderId: int): Order\n    +updateItemHash(orderItemId: int, qrHash: string): bool\n  }\n\n  interface ITicketRepository {\n    +getTicketTypeIdsBySchemeId(schemeId: int): array\n    +releaseMultiple(items: array): void\n    +getAvailableCapacity(ticketTypeId: int): int\n    +reserveMultiple(items: array): bool\n  }\n\n  class OrderRepository {\n    +getOrderByStripeCheckoutSessionId(sessionId: string): Order\n    +updateOrderStatus(orderId: int, status: OrderStatus, pdf: string = null): bool\n    +getOrderById(orderId: int): Order\n    +updateItemHash(orderItemId: int, qrHash: string): bool\n  }\n\n  class TicketRepository {\n    +getTicketTypeIdsBySchemeId(schemeId: int): array\n    +releaseMultiple(items: array): void\n    +getAvailableCapacity(ticketTypeId: int): int\n    +reserveMultiple(items: array): bool\n  }\n}\n\npackage \&quot;Domain Models\&quot; {\n  enum OrderStatus {\n    In_Cart\n    Pending_Payment\n    Paid\n    Fulfilled\n    Cancelled\n  }\n\n  class User {\n    +id: int\n    +email: string\n    +role: UserRole\n  }\n\n  class Order {\n    +order_id: int\n    +reference_number: string\n    +status: OrderStatus\n    +stripe_checkout_session_id: string\n    +ticket_pdf_path: string\n    +orderItems: OrderItem[]\n    +calculateTotals(): void\n  }\n\n  class OrderItem {\n    +orderitem_id: int\n    +quantity: int\n    +qr_code_hash: string\n    +ticket_type: TicketType\n    +createOrderItemFromTicketType(quantity: int, ticketType: TicketType): OrderItem\n  }\n\n  class TicketType {\n    +ticket_type_id: int\n    +capacity: int\n    +tickets_sold: int\n    +ticket_scheme: TicketScheme\n    +schedule: Schedule\n  }\n\n  class TicketScheme {\n    +ticket_scheme_id: int\n    +name: string\n    +scheme_enum: TicketSchemeEnum\n    +price: float\n    +fee: float\n  }\n\n  class Schedule {\n    +schedule_id: int\n  }\n}\n\nRouter ..&gt; StripeWebhookController : dispatches\\nPOST /stripe/webhook\nStripeWebhookController --|&gt; BaseController\n\nIPaymentService &lt;|.. PaymentService\nIOrderService &lt;|.. OrderService\nITicketService &lt;|.. TicketService\nITicketFulfillmentService &lt;|.. TicketFulfillmentService\nIMailService &lt;|.. MailService\nIOrderRepository &lt;|.. OrderRepository\nITicketRepository &lt;|.. TicketRepository\n\nOrderRepository --|&gt; Repository\nTicketRepository --|&gt; Repository\n\nStripeWebhookController --&gt; IPaymentService : verifies webhook\nStripeWebhookController --&gt; IOrderService : loads and updates order\nStripeWebhookController --&gt; ITicketService : releases seats on expiry\nStripeWebhookController --&gt; ITicketFulfillmentService : fulfills paid order\n\nOrderService --&gt; IOrderRepository : delegates persistence\nOrderService --&gt; TicketService : uses ticket logic\nTicketService --&gt; ITicketRepository : delegates ticket queries\nTicketFulfillmentService --&gt; IOrderService : generates hashes,\\nreloads order,\\nupdates pdf path\nTicketFulfillmentService --&gt; IMailService : sends ticket email\nMailService --&gt; Mailer : creates and uses\n\nOrder \&quot;1\&quot; *-- \&quot;0..*\&quot; OrderItem : contains\nOrder \&quot;0..*\&quot; --&gt; \&quot;1\&quot; User : belongs to\nOrderItem \&quot;0..*\&quot; --&gt; \&quot;1\&quot; TicketType : references\nTicketType \&quot;0..*\&quot; --&gt; \&quot;1\&quot; TicketScheme : priced by\nTicketType \&quot;0..*\&quot; --&gt; \&quot;1\&quot; Schedule : scheduled for\n\nnote bottom of StripeWebhookController\nHandles two webhook branches:\n- checkout.session.completed\n- checkout.session.expired\nend note\n\nnote bottom of Mailer\nExternal systems such as Stripe,\nPDF generation, and SMTP are\nshown in the sequence diagram\nas external participants rather\nthan internal classes.\nend note\n\n@enduml\n&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="tCxG6k3BUEs2lsI4PdtQ-1">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="1976" width="3071" x="-120" y="-80" as="geometry" />
          </mxCell>
        </UserObject>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
