<mxfile host="app.diagrams.net">
  <diagram name="Page-1" id="s82pQSyW2Ovad60uPZvh">
    <mxGraphModel dx="2400" dy="1007" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\ntitle Checkout Session Initiation - Class Diagram\n\nskinparam backgroundColor white\nskinparam shadowing false\nskinparam packageStyle rectangle\nskinparam classAttributeIconSize 0\nskinparam ArrowColor #4b5563\nskinparam ClassBorderColor #1f2937\nskinparam ClassBackgroundColor #f8fafc\nskinparam InterfaceBorderColor #0f766e\nskinparam InterfaceBackgroundColor #ecfeff\nskinparam NoteBackgroundColor #fff7ed\nskinparam NoteBorderColor #c2410c\n\nhide empty members\n\nclass \&quot;FastRoute Router\\n(public/index.php)\&quot; as Router &lt;&lt;router&gt;&gt; {\n  +dispatch(httpMethod, uri)\n}\n\npackage \&quot;Middleware\&quot; {\n  class RoleMiddleware {\n    +check(controller: object, methodName: string)\n  }\n\n  class RequireRole &lt;&lt;attribute&gt;&gt; {\n    +roles: array\n  }\n}\n\npackage \&quot;Controllers\&quot; {\n  abstract class BaseController {\n    #getLoggedInUser(): User\n    #sendSuccessResponse(data = [], code = 200): void\n    #sendErrorResponse(message, code = 500): void\n  }\n\n  class PaymentController {\n    -paymentService: IPaymentService\n    -orderService: IOrderService\n    -ticketFulfillmentService: ITicketFulfillmentService\n    -logService: ILogService\n    +index(params = []): void\n    +checkout(params = []): void\n    +createCheckoutSession(params = []): void\n    +status(params = []): void\n    +return(params = []): void\n  }\n}\n\npackage \&quot;Services\&quot; {\n  interface IPaymentService {\n    +stripeCheckout(item: object)\n    +stripeCheckoutStatus(jsonData: array): array\n  }\n\n  interface IOrderService {\n    +getSessionCart(): Order\n    +persistSessionCart(order: Order, user: User, ticketsAlreadyLocked: bool = false): Order\n    +hydrateSessionCart(order: Order): void\n    +setStripeCheckoutSessionId(orderId: int, sessionId: string): bool\n    +updateOrderStatus(orderId: int, status: OrderStatus, pdf: string = null): bool\n  }\n\n  interface ITicketService {\n    +reserveMultiple(items: array): bool\n    +getTicketTypeIdsBySchemeId(schemeId: int): array\n  }\n\n  interface ITicketFulfillmentService {\n    +isTicketPdfReady(filename: string): bool\n  }\n\n  interface ILogService {\n    +exception(category: string, e)\n    +info(category: string, message: string)\n  }\n\n  class PaymentService {\n    +stripeCheckout(item: object)\n    +stripeCheckoutStatus(jsonData: array): array\n  }\n\n  class OrderService {\n    -orderRepository: IOrderRepository\n    -ticketService: TicketService\n    +getSessionCart(): Order\n    +persistSessionCart(order: Order, user: User, ticketsAlreadyLocked: bool = false): Order\n    +hydrateSessionCart(order: Order): void\n    +setStripeCheckoutSessionId(orderId: int, sessionId: string): bool\n    +updateOrderStatus(orderId: int, status: OrderStatus, pdf: string = null): bool\n  }\n\n  class TicketService {\n    -ticketRepository: ITicketRepository\n    +reserveMultiple(items: array): bool\n    +getTicketTypeIdsBySchemeId(schemeId: int): array\n    +getAvailableCapacity(ticketTypeId: int): int\n  }\n\n  class TicketFulfillmentService {\n    +isTicketPdfReady(filename: string): bool\n  }\n\n  class LogService {\n    +exception(category: string, e)\n    +info(category: string, message: string)\n  }\n}\n\npackage \&quot;Repositories\&quot; {\n  abstract class Repository {\n    #pdo: PDO\n  }\n\n  interface IOrderRepository {\n    +createOrder(order: Order): bool\n    +addOrderItem(orderItem: OrderItem): bool\n    +updateOrderTotals(order: Order): bool\n    +setStripeCheckoutSessionId(orderId: int, sessionId: string): bool\n    +updateOrderStatus(orderId: int, status: OrderStatus, pdf: string = null): bool\n  }\n\n  interface ITicketRepository {\n    +reserveMultiple(items: array): bool\n    +getTicketTypeIdsBySchemeId(schemeId: int): array\n  }\n\n  class OrderRepository {\n    +createOrder(order: Order): bool\n    +addOrderItem(orderItem: OrderItem): bool\n    +updateOrderTotals(order: Order): bool\n    +setStripeCheckoutSessionId(orderId: int, sessionId: string): bool\n    +updateOrderStatus(orderId: int, status: OrderStatus, pdf: string = null): bool\n  }\n\n  class TicketRepository {\n    +reserveMultiple(items: array): bool\n    +getTicketTypeIdsBySchemeId(schemeId: int): array\n  }\n}\n\npackage \&quot;Domain Models\&quot; {\n  enum OrderStatus {\n    In_Cart\n    Pending_Payment\n    Paid\n    Fulfilled\n    Cancelled\n  }\n\n  class User {\n    +id: int\n    +email: string\n    +role: UserRole\n  }\n\n  class Order {\n    +order_id: int\n    +reference_number: string\n    +status: OrderStatus\n    +total: float\n    +stripe_checkout_session_id: string\n    +orderItems: OrderItem[]\n    +calculateTotals(): void\n  }\n\n  class OrderItem {\n    +orderitem_id: int\n    +quantity: int\n    +ticket_type: TicketType\n    +unit_price: float\n    +reservation_fee: float\n    +subtotal: float\n  }\n\n  class TicketType {\n    +ticket_type_id: int\n    +capacity: int\n    +tickets_sold: int\n    +ticket_scheme: TicketScheme\n  }\n\n  class TicketScheme {\n    +ticket_scheme_id: int\n    +scheme_enum: TicketSchemeEnum\n    +price: float\n  }\n}\n\nRouter ..&gt; RoleMiddleware : applies role check\nRouter ..&gt; PaymentController : dispatches\\n/create-checkout-session\nRoleMiddleware ..&gt; RequireRole : reads method attribute\n\nPaymentController --|&gt; BaseController\n\nIPaymentService &lt;|.. PaymentService\nIOrderService &lt;|.. OrderService\nITicketService &lt;|.. TicketService\nITicketFulfillmentService &lt;|.. TicketFulfillmentService\nILogService &lt;|.. LogService\nIOrderRepository &lt;|.. OrderRepository\nITicketRepository &lt;|.. TicketRepository\n\nOrderRepository --|&gt; Repository\nTicketRepository --|&gt; Repository\n\nPaymentController --&gt; IPaymentService : creates Stripe session\nPaymentController --&gt; IOrderService : loads and persists cart\nPaymentController --&gt; ILogService : logs failures\n\nOrderService --&gt; IOrderRepository : persists order and items\nOrderService --&gt; TicketService : reserves seats\nTicketService --&gt; ITicketRepository : ticket capacity operations\n\nOrder \&quot;1\&quot; *-- \&quot;0..*\&quot; OrderItem : contains\nOrder \&quot;0..*\&quot; --&gt; \&quot;1\&quot; User : belongs to\nOrderItem \&quot;0..*\&quot; --&gt; \&quot;1\&quot; TicketType : references\nTicketType \&quot;0..*\&quot; --&gt; \&quot;1\&quot; TicketScheme : priced by\n\nnote bottom of PaymentController\nThis feature documents the authenticated\ncheckout-start flow that turns a session cart\ninto a persisted order linked to a Stripe\ncheckout session.\nend note\n\nnote bottom of OrderService\nImportant rule:\nwhen the cart is persisted for checkout,\nticket capacity is reserved before the order\nand order items are stored in the database.\nend note\n\n@enduml\n&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="9_2U4ZhGvtanFrBnF6US-1">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="1664" width="3866" x="20" y="20" as="geometry" />
          </mxCell>
        </UserObject>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
