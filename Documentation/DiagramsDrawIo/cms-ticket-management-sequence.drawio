<mxfile host="app.diagrams.net">
  <diagram name="Page-1" id="l_zwBm2y3Smd1xmQKeZ2">
    <mxGraphModel dx="1800" dy="755" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\ntitle CMS Ticket Management - Create Ticket Type Sequence Diagram\n\nskinparam backgroundColor white\nskinparam shadowing false\nskinparam ArrowColor #4b5563\nskinparam LifeLineBorderColor #1f2937\nskinparam LifeLineBackgroundColor #f8fafc\nskinparam ParticipantBorderColor #1f2937\nskinparam ParticipantBackgroundColor #eff6ff\nskinparam ActorBorderColor #0f172a\nskinparam ActorBackgroundColor #dbeafe\nskinparam DatabaseBorderColor #14532d\nskinparam DatabaseBackgroundColor #dcfce7\nskinparam NoteBorderColor #c2410c\nskinparam NoteBackgroundColor #fff7ed\n\nactor \&quot;CMS Admin\&quot; as Admin\nparticipant \&quot;Router\\n(public/index.php)\&quot; as Router\nparticipant \&quot;RoleMiddleware\&quot; as RoleMiddleware\nparticipant \&quot;TicketController\&quot; as TicketController\nparticipant \&quot;ScheduleService\&quot; as ScheduleService\ndatabase \&quot;ScheduleRepository\&quot; as ScheduleRepository\nparticipant \&quot;TicketService\&quot; as TicketService\ndatabase \&quot;TicketRepository\&quot; as TicketRepository\nparticipant \&quot;LogService\&quot; as LogService\ncollections \&quot;PHP Session\&quot; as Session\n\nAdmin -&gt; Router : POST /cms/schedules/{scheduleId}/tickets/store\nRouter -&gt; RoleMiddleware : check(TicketController, \&quot;store\&quot;)\nactivate RoleMiddleware\n\nalt user is not ADMIN\n  RoleMiddleware --&gt; Router : deny access\n  Router --&gt; Admin : 404 / blocked request\nelse user is ADMIN\n  RoleMiddleware --&gt; Router : allow request\n\n  Router -&gt; TicketController : store(vars)\n  activate TicketController\n\n  TicketController -&gt; TicketController : startSession()\n  TicketController -&gt; TicketController : getScheduleOrThrow(scheduleId)\n  TicketController -&gt; ScheduleService : getScheduleById(scheduleId)\n  activate ScheduleService\n  ScheduleService -&gt; ScheduleRepository : getScheduleById(scheduleId)\n  activate ScheduleRepository\n  ScheduleRepository --&gt; ScheduleService : Schedule?\n  deactivate ScheduleRepository\n  ScheduleService --&gt; TicketController : Schedule?\n  deactivate ScheduleService\n\n  alt schedule not found\n    TicketController -&gt; LogService : exception(\&quot;Ticket\&quot;, e)\n    activate LogService\n    LogService --&gt; TicketController : logged\n    deactivate LogService\n    TicketController -&gt; Session : set $_SESSION[\&quot;error\&quot;]\n    TicketController -&gt; TicketController : redirect(\&quot;/cms/schedules\&quot;)\n    TicketController --&gt; Router : 302 redirect\n  else schedule exists\n    TicketController -&gt; TicketService : createFromRequest(scheduleId, $_POST)\n    activate TicketService\n\n    TicketService -&gt; TicketService : validateTicketTypeData(postData)\n    TicketService -&gt; TicketRepository : getTicketSchemeById(schemeId)\n    activate TicketRepository\n    TicketRepository --&gt; TicketService : TicketScheme?\n    deactivate TicketRepository\n\n    alt invalid form data or missing scheme\n      TicketService --&gt; TicketController : throws ValidationException\n      deactivate TicketService\n      TicketController -&gt; LogService : info(\&quot;Ticket\&quot;, \&quot;Validation error ...\&quot;)\n      activate LogService\n      LogService --&gt; TicketController : logged\n      deactivate LogService\n      TicketController -&gt; Session : set $_SESSION[\&quot;error\&quot;]\n      TicketController -&gt; TicketController : redirect(\&quot;/cms/schedules/{scheduleId}/tickets/create\&quot;)\n      TicketController --&gt; Router : 302 redirect\n    else basic validation passes\n      TicketService -&gt; TicketService : validateCapacityAgainstVenue(scheduleId, capacity)\n      TicketService -&gt; TicketRepository : getTotalAllocatedCapacityForSchedule(scheduleId)\n      activate TicketRepository\n      TicketRepository --&gt; TicketService : existingAllocated\n      deactivate TicketRepository\n      TicketService -&gt; TicketRepository : getVenueCapacityForSchedule(scheduleId)\n      activate TicketRepository\n      TicketRepository --&gt; TicketService : venueCapacity?\n      deactivate TicketRepository\n\n      alt allocated + newCapacity &gt; venueCapacity\n        note right of TicketService\n          Business rule:\n          total allocated ticket capacity\n          may not exceed venue capacity.\n        end note\n        TicketService --&gt; TicketController : throws ValidationException\n        deactivate TicketService\n        TicketController -&gt; LogService : info(\&quot;Ticket\&quot;, \&quot;Validation error ...\&quot;)\n        activate LogService\n        LogService --&gt; TicketController : logged\n        deactivate LogService\n        TicketController -&gt; Session : set $_SESSION[\&quot;error\&quot;]\n        TicketController -&gt; TicketController : redirect(\&quot;/cms/schedules/{scheduleId}/tickets/create\&quot;)\n        TicketController --&gt; Router : 302 redirect\n      else capacity is valid\n        note right of TicketService\n          If no venue is linked to the\n          schedule, capacity validation\n          allows the ticket type to proceed.\n        end note\n        TicketService -&gt; TicketRepository : getTicketSchemeById(schemeId)\n        activate TicketRepository\n        TicketRepository --&gt; TicketService : TicketScheme\n        deactivate TicketRepository\n        TicketService -&gt; TicketRepository : create(ticketType)\n        activate TicketRepository\n        TicketRepository --&gt; TicketService : inserted + ticket_type_id\n        deactivate TicketRepository\n        TicketService --&gt; TicketController : TicketType\n        deactivate TicketService\n\n        TicketController -&gt; Session : set $_SESSION[\&quot;success\&quot;]\n        TicketController -&gt; TicketController : redirect(\&quot;/cms/schedules/{scheduleId}/tickets\&quot;)\n        TicketController --&gt; Router : 302 redirect\n      end\n    end\n  end\n  Router --&gt; Admin : redirected CMS response\n  deactivate TicketController\nend\n\ndeactivate RoleMiddleware\n\nnote over TicketController, TicketRepository\nThis sequence documents the admin request path for\ncreating a ticket type from the CMS schedule screen.\nend note\n\n@enduml\n&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="iuxjtMuXlwj81J-36Wjr-1">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="1977" width="2100" x="20" y="20" as="geometry" />
          </mxCell>
        </UserObject>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
