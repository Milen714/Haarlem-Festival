<mxfile host="app.diagrams.net">
  <diagram name="Page-1" id="80HL9dWjSkSfcFbAoIQF">
    <mxGraphModel dx="2618" dy="1098" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\ntitle Stripe Ticket Fulfillment - Sequence Diagram\n\nskinparam backgroundColor white\nskinparam shadowing false\nskinparam ArrowColor #4b5563\nskinparam LifeLineBorderColor #1f2937\nskinparam LifeLineBackgroundColor #f8fafc\nskinparam ParticipantBorderColor #1f2937\nskinparam ParticipantBackgroundColor #eff6ff\nskinparam ActorBorderColor #0f172a\nskinparam ActorBackgroundColor #dbeafe\nskinparam DatabaseBorderColor #14532d\nskinparam DatabaseBackgroundColor #dcfce7\nskinparam NoteBorderColor #c2410c\nskinparam NoteBackgroundColor #fff7ed\n\nactor Stripe\nparticipant \&quot;Router\\n(public/index.php)\&quot; as Router\nparticipant \&quot;StripeWebhookController\&quot; as Controller\nparticipant \&quot;PaymentService\&quot; as PaymentService\nparticipant \&quot;OrderService\&quot; as OrderService\ndatabase \&quot;OrderRepository\&quot; as OrderRepository\nparticipant \&quot;TicketService\&quot; as TicketService\ndatabase \&quot;TicketRepository\&quot; as TicketRepository\nparticipant \&quot;TicketFulfillmentService\&quot; as FulfillmentService\nparticipant \&quot;MailService\&quot; as MailService\ndatabase \&quot;PDF Storage\\n(app/TicketPDFs)\&quot; as PdfStorage\ncollections \&quot;SMTP Mail Server\&quot; as MailServer\n\nStripe -&gt; Router : POST /stripe/webhook\\npayload + Stripe-Signature\nRouter -&gt; Controller : handle(params)\nactivate Controller\n\nController -&gt; PaymentService : verifyWebhookSignature(payload, sigHeader)\nactivate PaymentService\nPaymentService --&gt; Controller : Stripe event\ndeactivate PaymentService\n\nalt event.type == checkout.session.completed\n  alt session.payment_status != \&quot;paid\&quot;\n    note right of Controller\n      Ignore completed sessions\n      that are not actually paid.\n    end note\n  else paid session\n    Controller -&gt; OrderService : getOrderByStripeCheckoutSessionId(session.id)\n    activate OrderService\n    OrderService -&gt; OrderRepository : getOrderByStripeCheckoutSessionId(session.id)\n    activate OrderRepository\n    OrderRepository --&gt; OrderService : Order + OrderItems\n    deactivate OrderRepository\n    OrderService --&gt; Controller : Order\n    deactivate OrderService\n\n    alt order == null or order.status == Paid\n      note right of Controller\n        Ignore missing orders and\n        already-paid orders.\n      end note\n    else process fulfillment\n      Controller -&gt; OrderService : updateOrderStatus(order.order_id, Paid)\n      activate OrderService\n      OrderService -&gt; OrderRepository : updateOrderStatus(orderId, Paid)\n      activate OrderRepository\n      OrderRepository --&gt; OrderService : true\n      deactivate OrderRepository\n      OrderService --&gt; Controller : true\n      deactivate OrderService\n\n      Controller -&gt; Controller : renderViewToString(\&quot;Email/TicketsPDF\&quot;, viewModel)\n      Controller -&gt; Controller : renderViewToString(\&quot;Email/TicketsMailBody\&quot;, viewModel)\n\n      Controller -&gt; FulfillmentService : sendTicketEmail(order, pdfHtml, emailHtml)\n      activate FulfillmentService\n\n      FulfillmentService -&gt; OrderService : generateTicketHashes(order.order_id)\n      activate OrderService\n      OrderService -&gt; OrderRepository : getOrderItemsByOrderId(orderId)\n      activate OrderRepository\n      OrderRepository --&gt; OrderService : OrderItem[]\n      deactivate OrderRepository\n      loop for each order item\n        OrderService -&gt; OrderRepository : updateItemHash(orderitem_id, qr_code_hash)\n        activate OrderRepository\n        OrderRepository --&gt; OrderService : true\n        deactivate OrderRepository\n      end\n      OrderService --&gt; FulfillmentService : void\n      deactivate OrderService\n\n      FulfillmentService -&gt; OrderService : getOrderById(order.order_id)\n      activate OrderService\n      OrderService -&gt; OrderRepository : getOrderById(orderId)\n      activate OrderRepository\n      OrderRepository --&gt; OrderService : refreshed Order\n      deactivate OrderRepository\n      OrderService --&gt; FulfillmentService : refreshed Order\n      deactivate OrderService\n\n      FulfillmentService -&gt; FulfillmentService : generatePDFName(order)\n      FulfillmentService -&gt; FulfillmentService : generatePDF(pdfHtml, fileName)\n      FulfillmentService -&gt; PdfStorage : save fileName.pdf\n      activate PdfStorage\n      PdfStorage --&gt; FulfillmentService : stored pdf path\n      deactivate PdfStorage\n\n      FulfillmentService -&gt; OrderService : updateOrderStatus(orderId, currentStatus, ticket_pdf_path)\n      activate OrderService\n      OrderService -&gt; OrderRepository : updateOrderStatus(orderId, currentStatus, ticket_pdf_path)\n      activate OrderRepository\n      OrderRepository --&gt; OrderService : true\n      deactivate OrderRepository\n      OrderService --&gt; FulfillmentService : true\n      deactivate OrderService\n\n      FulfillmentService -&gt; MailService : sendEmail(user.email, subject, emailHtml, [pdf])\n      activate MailService\n      MailService -&gt; MailServer : send email with PDF attachment\n      activate MailServer\n      MailServer --&gt; MailService : accepted\n      deactivate MailServer\n      MailService --&gt; FulfillmentService : void\n      deactivate MailService\n\n      FulfillmentService --&gt; Controller : pdf filename\n      deactivate FulfillmentService\n\n      Controller -&gt; OrderService : updateOrderStatus(order.order_id, Fulfilled, pdf_path)\n      activate OrderService\n      OrderService -&gt; OrderRepository : updateOrderStatus(orderId, Fulfilled, pdf_path)\n      activate OrderRepository\n      OrderRepository --&gt; OrderService : true\n      deactivate OrderRepository\n      OrderService --&gt; Controller : true\n      deactivate OrderService\n    end\n  end\nelse event.type == checkout.session.expired\n  Controller -&gt; OrderService : getOrderByStripeCheckoutSessionId(session.id)\n  activate OrderService\n  OrderService -&gt; OrderRepository : getOrderByStripeCheckoutSessionId(session.id)\n  activate OrderRepository\n  OrderRepository --&gt; OrderService : Order + OrderItems\n  deactivate OrderRepository\n  OrderService --&gt; Controller : Order\n  deactivate OrderService\n\n  alt order == null or order.status == Cancelled\n    note right of Controller\n      Ignore missing orders and\n      already-cancelled orders.\n    end note\n  else cancel and release\n    Controller -&gt; TicketService : releaseOrderItems(order.orderItems)\n    activate TicketService\n    TicketService -&gt; TicketRepository : getTicketTypeIdsBySchemeId(...) [pass tickets only]\n    activate TicketRepository\n    TicketRepository --&gt; TicketService : sibling ticket type ids\n    deactivate TicketRepository\n    TicketService -&gt; TicketRepository : releaseMultiple(items)\n    activate TicketRepository\n    TicketRepository --&gt; TicketService : released\n    deactivate TicketRepository\n    TicketService --&gt; Controller : void\n    deactivate TicketService\n\n    Controller -&gt; OrderService : updateOrderStatus(order.order_id, Cancelled)\n    activate OrderService\n    OrderService -&gt; OrderRepository : updateOrderStatus(orderId, Cancelled)\n    activate OrderRepository\n    OrderRepository --&gt; OrderService : true\n    deactivate OrderRepository\n    OrderService --&gt; Controller : true\n    deactivate OrderService\n  end\nend\n\nController --&gt; Router : sendSuccessResponse({\&quot;received\&quot;: true}, 200)\ndeactivate Controller\nRouter --&gt; Stripe : 200 OK\n\nnote over Controller, MailServer\nDocumented state transitions:\nPending_Payment -&gt; Paid -&gt; Fulfilled\nPending_Payment -&gt; Cancelled\nend note\n\n@enduml\n&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="XbtpqZT3fZomthEic32B-1">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="2323" width="2773" x="20" y="20" as="geometry" />
          </mxCell>
        </UserObject>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
