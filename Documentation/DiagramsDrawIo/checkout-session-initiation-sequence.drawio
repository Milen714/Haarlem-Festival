<mxfile host="app.diagrams.net">
  <diagram name="Page-1" id="AXEaJO6iS7jtlNwR7XUT">
    <mxGraphModel dx="4114" dy="1726" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\ntitle Checkout Session Initiation - Sequence Diagram\n\nskinparam backgroundColor white\nskinparam shadowing false\nskinparam ArrowColor #4b5563\nskinparam LifeLineBorderColor #1f2937\nskinparam LifeLineBackgroundColor #f8fafc\nskinparam ParticipantBorderColor #1f2937\nskinparam ParticipantBackgroundColor #eff6ff\nskinparam ActorBorderColor #0f172a\nskinparam ActorBackgroundColor #dbeafe\nskinparam DatabaseBorderColor #14532d\nskinparam DatabaseBackgroundColor #dcfce7\nskinparam NoteBorderColor #c2410c\nskinparam NoteBackgroundColor #fff7ed\n\nactor \&quot;Logged-in Customer\&quot; as Customer\nparticipant \&quot;Router\\n(public/index.php)\&quot; as Router\nparticipant \&quot;RoleMiddleware\&quot; as RoleMiddleware\nparticipant \&quot;PaymentController\&quot; as PaymentController\nparticipant \&quot;OrderService\&quot; as OrderService\ncollections \&quot;PHP Session\&quot; as Session\nparticipant \&quot;TicketService\&quot; as TicketService\ndatabase \&quot;TicketRepository\&quot; as TicketRepository\ndatabase \&quot;OrderRepository\&quot; as OrderRepository\nparticipant \&quot;PaymentService\&quot; as PaymentService\nparticipant \&quot;Stripe Checkout API\&quot; as Stripe\nparticipant \&quot;LogService\&quot; as LogService\n\nCustomer -&gt; Router : GET /create-checkout-session\nRouter -&gt; RoleMiddleware : check(PaymentController, \&quot;createCheckoutSession\&quot;)\nactivate RoleMiddleware\n\nalt user is not allowed\n  RoleMiddleware --&gt; Router : deny access\n  Router --&gt; Customer : blocked request\nelse user is allowed\n  RoleMiddleware --&gt; Router : allow request\n\n  Router -&gt; PaymentController : createCheckoutSession(params)\n  activate PaymentController\n\n  PaymentController -&gt; OrderService : getSessionCart()\n  activate OrderService\n  OrderService -&gt; Session : read $_SESSION[\&quot;session_cart\&quot;]\n  Session --&gt; OrderService : Order?\n  OrderService --&gt; PaymentController : Order?\n  deactivate OrderService\n\n  alt order == null or order.orderItems is empty\n    PaymentController -&gt; LogService : exception(\&quot;Payment\&quot;, e)\n    activate LogService\n    LogService --&gt; PaymentController : logged\n    deactivate LogService\n    PaymentController --&gt; Router : sendErrorResponse(\&quot;No active cart found.\&quot;, 400/500)\n  else order.order_id == null\n    PaymentController -&gt; PaymentController : getLoggedInUser()\n    PaymentController -&gt; OrderService : persistSessionCart(order, user)\n    activate OrderService\n    OrderService -&gt; OrderService : calculateTotals()\n    OrderService -&gt; TicketService : reserveMultiple(items)\n    activate TicketService\n    TicketService -&gt; TicketRepository : reserveMultiple(items)\n    activate TicketRepository\n    TicketRepository --&gt; TicketService : reserved?\n    deactivate TicketRepository\n    TicketService --&gt; OrderService : true/false\n    deactivate TicketService\n\n    alt reserveMultiple returns false\n      OrderService --&gt; PaymentController : throws ValidationException\n      deactivate OrderService\n      PaymentController -&gt; LogService : exception(\&quot;Payment\&quot;, e)\n      activate LogService\n      LogService --&gt; PaymentController : logged\n      deactivate LogService\n      PaymentController --&gt; Router : sendErrorResponse(\&quot;Sold out / insufficient capacity\&quot;, 400/500)\n    else seats reserved\n      OrderService -&gt; OrderRepository : createOrder(order)\n      activate OrderRepository\n      OrderRepository --&gt; OrderService : inserted + order_id\n      deactivate OrderRepository\n\n      loop for each order item\n        OrderService -&gt; OrderRepository : addOrderItem(orderItem)\n        activate OrderRepository\n        OrderRepository --&gt; OrderService : inserted + orderitem_id\n        deactivate OrderRepository\n      end\n\n      OrderService --&gt; PaymentController : persisted Order\n      deactivate OrderService\n\n      PaymentController -&gt; OrderService : hydrateSessionCart(order)\n      activate OrderService\n      OrderService -&gt; Session : write $_SESSION[\&quot;session_cart\&quot;]\n      Session --&gt; OrderService : stored\n      OrderService --&gt; PaymentController : void\n      deactivate OrderService\n\n      PaymentController -&gt; PaymentController : order.calculateTotals()\n      PaymentController -&gt; PaymentService : stripeCheckout(item)\n      activate PaymentService\n      PaymentService -&gt; Stripe : create embedded checkout session\n      activate Stripe\n      Stripe --&gt; PaymentService : session.id + client_secret\n      deactivate Stripe\n      PaymentService --&gt; PaymentController : Stripe session\n      deactivate PaymentService\n\n      PaymentController -&gt; OrderService : setStripeCheckoutSessionId(order.order_id, stripeSession.id)\n      activate OrderService\n      OrderService -&gt; OrderRepository : setStripeCheckoutSessionId(orderId, sessionId)\n      activate OrderRepository\n      OrderRepository --&gt; OrderService : true\n      deactivate OrderRepository\n      OrderService --&gt; PaymentController : true\n      deactivate OrderService\n\n      PaymentController -&gt; OrderService : updateOrderStatus(order.order_id, Pending_Payment)\n      activate OrderService\n      OrderService -&gt; OrderRepository : updateOrderStatus(orderId, Pending_Payment)\n      activate OrderRepository\n      OrderRepository --&gt; OrderService : true\n      deactivate OrderRepository\n      OrderService --&gt; PaymentController : true\n      deactivate OrderService\n\n      PaymentController --&gt; Router : sendSuccessResponse({clientSecret}, 200)\n    end\n  else order already persisted\n    PaymentController -&gt; PaymentController : order.calculateTotals()\n    PaymentController -&gt; PaymentService : stripeCheckout(item)\n    activate PaymentService\n    PaymentService -&gt; Stripe : create embedded checkout session\n    activate Stripe\n    Stripe --&gt; PaymentService : session.id + client_secret\n    deactivate Stripe\n    PaymentService --&gt; PaymentController : Stripe session\n    deactivate PaymentService\n\n    PaymentController -&gt; OrderService : setStripeCheckoutSessionId(order.order_id, stripeSession.id)\n    activate OrderService\n    OrderService -&gt; OrderRepository : setStripeCheckoutSessionId(orderId, sessionId)\n    activate OrderRepository\n    OrderRepository --&gt; OrderService : true\n    deactivate OrderRepository\n    OrderService --&gt; PaymentController : true\n    deactivate OrderService\n\n    PaymentController -&gt; OrderService : updateOrderStatus(order.order_id, Pending_Payment)\n    activate OrderService\n    OrderService -&gt; OrderRepository : updateOrderStatus(orderId, Pending_Payment)\n    activate OrderRepository\n    OrderRepository --&gt; OrderService : true\n    deactivate OrderRepository\n    OrderService --&gt; PaymentController : true\n    deactivate OrderService\n\n    PaymentController --&gt; Router : sendSuccessResponse({clientSecret}, 200)\n  end\n\n  deactivate PaymentController\n  Router --&gt; Customer : JSON response\nend\n\ndeactivate RoleMiddleware\n\nnote over PaymentController, Stripe\nKey state transition in this flow:\nIn_Cart -&gt; Pending_Payment\nend note\n\nnote over OrderService, TicketRepository\nBefore checkout can start for a new persisted order,\nthe service reserves ticket capacity, including\npass-type sibling ticket types when applicable.\nend note\n\n@enduml\n&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="oZKs7SpFtIvZLSx_1w8X-1">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="2282" width="2386" x="20" y="20" as="geometry" />
          </mxCell>
        </UserObject>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
