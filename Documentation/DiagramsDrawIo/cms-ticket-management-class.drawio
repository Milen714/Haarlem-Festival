<mxfile host="app.diagrams.net">
  <diagram name="Page-1" id="b4NKQDzsZie8vFFn21qK">
    <mxGraphModel dx="2215" dy="929" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\ntitle CMS Ticket Management - Class Diagram\n\nskinparam backgroundColor white\nskinparam shadowing false\nskinparam packageStyle rectangle\nskinparam classAttributeIconSize 0\nskinparam ArrowColor #4b5563\nskinparam ClassBorderColor #1f2937\nskinparam ClassBackgroundColor #f8fafc\nskinparam InterfaceBorderColor #0f766e\nskinparam InterfaceBackgroundColor #ecfeff\nskinparam NoteBackgroundColor #fff7ed\nskinparam NoteBorderColor #c2410c\n\nhide empty members\n\nclass \&quot;FastRoute Router\\n(public/index.php)\&quot; as Router &lt;&lt;router&gt;&gt; {\n  +dispatch(httpMethod, uri)\n}\n\npackage \&quot;Middleware\&quot; {\n  class RoleMiddleware {\n    +check(controller: object, methodName: string)\n  }\n\n  class RequireRole &lt;&lt;attribute&gt;&gt; {\n    +roles: array\n  }\n}\n\npackage \&quot;Controllers\&quot; {\n  abstract class BaseController {\n    #cmsLayout(viewName, vars = [], layout = \&quot;layouts/CmsLayout\&quot;)\n    #redirect(url)\n  }\n\n  class TicketController {\n    -ticketService: TicketService\n    -scheduleService: ScheduleService\n    -logService: ILogService\n    +index(vars = []): void\n    +create(vars = []): void\n    +store(vars = []): void\n    +edit(vars = []): void\n    +update(vars = []): void\n    +delete(vars = []): void\n    +schemeIndex(vars = []): void\n    +schemeCreate(vars = []): void\n    +schemeStore(vars = []): void\n    -getScheduleOrThrow(scheduleId: int)\n    -getTicketTypeForScheduleOrThrow(scheduleId: int, ticketTypeId: int)\n    -startSession(): void\n  }\n}\n\npackage \&quot;Services\&quot; {\n  interface ITicketService {\n    +getTicketTypeById(ticketTypeId: int): TicketType\n    +getTicketTypesByScheduleId(scheduleId: int): array\n    +createFromRequest(scheduleId: int, postData: array): TicketType\n    +updateFromRequest(ticketTypeId: int, scheduleId: int, postData: array): TicketType\n    +getAllTicketSchemes(): array\n    +validateCapacityAgainstVenue(scheduleId: int, newCapacity: int, excludeTicketTypeId: int = null): void\n  }\n\n  interface IScheduleService {\n    +getScheduleById(scheduleId: int): Schedule\n  }\n\n  interface ILogService {\n    +info(category: string, message: string)\n    +exception(category: string, e)\n  }\n\n  class TicketService {\n    -ticketRepository: ITicketRepository\n    +getTicketTypeById(ticketTypeId: int): TicketType\n    +getTicketTypesByScheduleId(scheduleId: int): array\n    +getAllTicketSchemes(): array\n    +createFromRequest(scheduleId: int, postData: array): TicketType\n    +updateFromRequest(ticketTypeId: int, scheduleId: int, postData: array): TicketType\n    +validateCapacityAgainstVenue(scheduleId: int, newCapacity: int, excludeTicketTypeId: int = null): void\n    -validateTicketTypeData(postData: array): void\n    -buildTicketTypeFromPostData(ticketType: TicketType, scheduleId: int, postData: array): TicketType\n  }\n\n  class ScheduleService {\n    -scheduleRepository: ScheduleRepository\n    +getScheduleById(scheduleId: int): Schedule\n  }\n\n  class LogService {\n    +info(category: string, message: string)\n    +exception(category: string, e)\n  }\n}\n\npackage \&quot;Repositories\&quot; {\n  abstract class Repository {\n    #pdo: PDO\n  }\n\n  interface ITicketRepository {\n    +getTicketTypeById(ticketTypeId: int): TicketType\n    +getTicketTypesByScheduleId(scheduleId: int): array\n    +create(ticketType: TicketType): bool\n    +update(ticketType: TicketType): bool\n    +delete(ticketTypeId: int): bool\n    +getTicketSchemeById(ticketSchemeId: int): TicketScheme\n    +getAllTicketSchemes(): array\n    +getTotalAllocatedCapacityForSchedule(scheduleId: int, excludeTicketTypeId: int = null): int\n    +getVenueCapacityForSchedule(scheduleId: int): int\n  }\n\n  interface IScheduleRepository {\n    +getScheduleById(scheduleId: int): Schedule\n  }\n\n  class TicketRepository {\n    +getTicketTypeById(ticketTypeId: int): TicketType\n    +getTicketTypesByScheduleId(scheduleId: int): array\n    +create(ticketType: TicketType): bool\n    +update(ticketType: TicketType): bool\n    +delete(ticketTypeId: int): bool\n    +getTicketSchemeById(ticketSchemeId: int): TicketScheme\n    +getAllTicketSchemes(): array\n    +getTotalAllocatedCapacityForSchedule(scheduleId: int, excludeTicketTypeId: int = null): int\n    +getVenueCapacityForSchedule(scheduleId: int): int\n  }\n\n  class ScheduleRepository {\n    +getScheduleById(scheduleId: int): Schedule\n  }\n}\n\npackage \&quot;Domain Models\&quot; {\n  class Schedule {\n    +schedule_id: int\n    +total_capacity: int\n    +venue: Venue\n    +ticketTypes: TicketType[]\n    +hydrateSchedule(row: array): Schedule\n  }\n\n  class Venue {\n    +venue_id: int\n    +name: string\n    +capacity: int\n  }\n\n  class TicketType {\n    +ticket_type_id: int\n    +description: string\n    +min_quantity: int\n    +max_quantity: int\n    +capacity: int\n    +tickets_sold: int\n    +schedule: Schedule\n    +ticket_scheme: TicketScheme\n  }\n\n  class TicketScheme {\n    +ticket_scheme_id: int\n    +name: string\n    +scheme_enum: TicketSchemeEnum\n    +price: float\n    +ticket_language: TicketLanguageEnum\n  }\n}\n\nRouter ..&gt; RoleMiddleware : applies role check\nRouter ..&gt; TicketController : dispatches\\n/cms/schedules/{scheduleId}/tickets/*\nRoleMiddleware ..&gt; RequireRole : reads method attribute\n\nTicketController --|&gt; BaseController\n\nITicketService &lt;|.. TicketService\nIScheduleService &lt;|.. ScheduleService\nILogService &lt;|.. LogService\nITicketRepository &lt;|.. TicketRepository\nIScheduleRepository &lt;|.. ScheduleRepository\n\nTicketRepository --|&gt; Repository\nScheduleRepository --|&gt; Repository\n\nTicketController --&gt; ITicketService : ticket CRUD\nTicketController --&gt; IScheduleService : load schedule\nTicketController --&gt; ILogService : log errors\n\nTicketService --&gt; ITicketRepository : validation and persistence\nScheduleService --&gt; IScheduleRepository : load schedule\n\nSchedule \&quot;1\&quot; o-- \&quot;0..*\&quot; TicketType : contains\nSchedule \&quot;0..*\&quot; --&gt; \&quot;0..1\&quot; Venue : hosted at\nTicketType \&quot;0..*\&quot; --&gt; \&quot;1\&quot; TicketScheme : uses\nTicketType \&quot;0..*\&quot; --&gt; \&quot;1\&quot; Schedule : belongs to\n\nnote bottom of TicketService\nKey business rule:\ntotal ticket capacity allocated\nto a schedule may not exceed\nthe linked venue capacity.\nend note\n\nnote bottom of TicketController\nThis feature covers the admin CMS flow\nfor listing, creating, editing, and\ndeleting ticket types and ticket schemes.\nend note\n\n@enduml\n&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="aaTe0Om7bVKYezSokzSg-1">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="1692" width="3096" x="20" y="20" as="geometry" />
          </mxCell>
        </UserObject>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
