{
  "info": {
    "name": "Orders Export API",
    "description": "Postman collection for order export functionality",
    "version": "1.0.0",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Get Available Order Columns",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "application/json",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{base_url}}/orders/columns",
          "host": ["{{base_url}}"],
          "path": ["orders", "columns"]
        },
        "description": "Fetch all available columns from the ORDER table for export selection"
      },
      "response": []
    },
    {
      "name": "Export Orders - All Columns",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          },
          {
            "key": "Accept",
            "value": "text/csv",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"columns\": [\n    \"order_id\",\n    \"user_id\",\n    \"reference_number\",\n    \"order_date\",\n    \"subtotal\",\n    \"total\",\n    \"serviceFee\",\n    \"reservationFees\",\n    \"currency\",\n    \"status\",\n    \"created_at\",\n    \"paid_at\"\n  ]\n}"
        },
        "url": {
          "raw": "{{base_url}}/orders/export",
          "host": ["{{base_url}}"],
          "path": ["orders", "export"]
        },
        "description": "Export all orders with all selected columns as CSV"
      },
      "response": []
    },
    {
      "name": "Export Orders - Specific Columns",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          },
          {
            "key": "Accept",
            "value": "text/csv",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"columns\": [\n    \"order_id\",\n    \"reference_number\",\n    \"order_date\",\n    \"total\",\n    \"status\",\n    \"paid_at\"\n  ]\n}"
        },
        "url": {
          "raw": "{{base_url}}/orders/export",
          "host": ["{{base_url}}"],
          "path": ["orders", "export"]
        },
        "description": "Export orders with selected columns only"
      },
      "response": []
    },
    {
      "name": "Export Orders - With Paid After Filter",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          },
          {
            "key": "Accept",
            "value": "text/csv",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"columns\": [\n    \"order_id\",\n    \"reference_number\",\n    \"total\",\n    \"status\",\n    \"paid_at\"\n  ],\n  \"paidAfter\": \"2024-01-01 00:00:00\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/orders/export",
          "host": ["{{base_url}}"],
          "path": ["orders", "export"]
        },
        "description": "Export orders paid after a specific date with selected columns"
      },
      "response": []
    },
    {
      "name": "Export Orders - Error Case (No Columns)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"columns\": []\n}"
        },
        "url": {
          "raw": "{{base_url}}/orders/export",
          "host": ["{{base_url}}"],
          "path": ["orders", "export"]
        },
        "description": "Test error handling - should return 400 error (No columns specified)"
      },
      "response": []
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000",
      "type": "string",
      "description": "Base URL for the API - update to your server URL"
    }
  ]
}
