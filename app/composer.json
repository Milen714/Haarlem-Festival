{
  "name": "docker-template/app",
  "type": "project",
  "require": {
    "nikic/fast-route": "^1.3",
    "vlucas/phpdotenv": "^5.6",
    "phpmailer/phpmailer": "^6.9",
    "tinymce/tinymce": "6.8",
    "stripe/stripe-php": "^19.4",
    "dompdf/dompdf": "^3.1",
    "chillerlan/php-qrcode": "^6.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/",
      "App\\config\\": "config/",
      "App\\CmsModels\\": "CmsModels/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "App\\Tests\\": "tests/"
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
